{% assign p_alpenglow = all_products['alpenglow-freeride-158'] %}
{% assign p_couloir = all_products['couloir-all-mountain-154'] %}
{% assign p_drift = all_products['drift-park-twin-150'] %}
{% assign p_bindings = all_products['quantora-bindings'] %}
{% assign p_bags = all_products['quantora-board-bag'] %}
{% assign p_kits = all_products['quantora-tuning-kit'] %}
{% assign p_poles = all_products['quantora-poles-straps'] %}

<div class="quantora-apple-layout">
  <section class="hero">
    <div class="eyebrow reveal in">Quantora</div>
    <h1 class="reveal in">The board that<br>reads the mountain.</h1>
    <p class="sub reveal in">Carbon-tuned snowboards, engineered layers, and gear built for one thing.</p>
    <div class="cta-row reveal in">
      <a class="pill pill-blue" href="/collections/automated-collection">Shop Snowboards</a>
      <a class="link-blue" href="#lineup">Learn more <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 6l6 6-6 6"/></svg></a>
    </div>
    <div class="hero-visual reveal">
      <div class="stage" style="background:#000;">
        <video 
          autoplay 
          loop 
          muted 
          playsinline 
          style="width:100%; height:100%; object-fit:cover; display:block;"
        >
          <source src="https://player.vimeo.com/external/371433846.sd.mp4?s=236da2f3c054a1240e94a5df1e6cc47c2b3fb81d&profile_id=164&oauth2_token_id=57447761" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </section>

  <section class="section dark" id="lineup">
    <div class="section-head reveal">
      <div class="eyebrow" style="color:#9a9a9e;">Snowboards</div>
      <h2>Precision, carved in.</h2>
      <p class="sub">All-mountain. Freeride. Park. Every shape, tuned for a different line down.</p>
    </div>
    <div class="links-inline reveal">
      <a class="link-blue" href="/collections/automated-collection">Shop Snowboards <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 6l6 6-6 6"/></svg></a>
      <a class="link-blue" href="#compare">Compare models <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 6l6 6-6 6"/></svg></a>
    </div>
    <div class="hero-visual reveal">
      <div class="stage" style="background:radial-gradient(circle at 50% 30%, #1c1c1e, #000000);">
        <svg viewBox="0 0 500 260">
          <g>
            <path d="M60 200 C90 100 160 70 250 70 C340 70 410 100 440 200" fill="none" stroke="#ffffff" stroke-width="2" opacity=".9"/>
            <path d="M60 210 C90 120 160 90 250 90 C340 90 410 120 440 210" fill="none" stroke="#0071E3" stroke-width="2" opacity=".8"/>
            <path d="M60 220 C90 140 160 110 250 110 C340 110 410 140 440 220" fill="none" stroke="#3a3a3c" stroke-width="1.5"/>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <section class="section fog">
    <div class="section-head reveal">
      <div class="eyebrow" style="color:var(--ink-soft);">Shop the lineup</div>
      <h2>Everything for the descent.</h2>
      <p class="sub">Four categories. Built to work together, sold to stand alone.</p>
    </div>

    <div class="grid-2 reveal">
      <a class="prod-card" style="background:linear-gradient(160deg,#eef1f5,#dfe6ec);" href="/collections/clothing-layers">
        <div class="eyebrow-sm">Clothing &amp; Layers</div>
        <h3>Dress for the storm.</h3>
        <p>Waterproof shells and breathable base layers, built to move with you.</p>
        <div class="links">
          <span>Shop &gt;</span>
          <span style="margin-left: 18px; color: var(--blue);">Learn more &gt;</span>
        </div>
        <div class="visual">
          <svg viewBox="0 0 120 140"><path d="M20 20 L45 8 L60 18 L75 8 L100 20 L92 44 L80 38 L80 132 L40 132 L40 38 L28 44 Z" fill="#1D1D1F"/></svg>
        </div>
      </a>

      <a class="prod-card" style="background:linear-gradient(160deg,#101112,#000000); color:#fff;" href="/collections/safety-accessories">
        <div class="eyebrow-sm" style="color:#9a9a9e;">Safety &amp; Accessories</div>
        <h3>Ride protected.</h3>
        <p style="color:#9a9a9e;">Beacons, armor, and optics — the gear you hope you never need.</p>
        <div class="links">
          <span style="color:#409CFF;">Shop &gt;</span>
          <span style="margin-left: 18px; color:#409CFF;">Learn more &gt;</span>
        </div>
        <div class="visual">
          <svg viewBox="0 0 120 120"><circle cx="60" cy="60" r="42" fill="none" stroke="#409CFF" stroke-width="3"/><circle cx="60" cy="60" r="24" fill="none" stroke="#3a3a3c" stroke-width="2"/></svg>
        </div>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="section-head reveal">
      <div class="eyebrow" style="color:var(--ink-soft);">Equipment</div>
      <h2>The hardware that ties it together.</h2>
      <p class="sub">Bindings, tools, and travel gear — built to disappear once you're riding.</p>
    </div>
    <div class="links-inline reveal">
      <a class="link-blue" href="/collections/equipment">Shop Equipment <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 6l6 6-6 6"/></svg></a>
    </div>
    <div class="grid-4 reveal">
      <a class="small-card" style="background:var(--fog);" href="{% if p_bindings != blank %}{{ p_bindings.url }}{% else %}/collections/equipment{% endif %}">
        <h4>Bindings</h4>
        <p>Tool-free adjustment, dialed for any boot.</p>
        <span style="color: var(--blue); font-size: 13px;">Shop &gt;</span>
        <div class="visual"><svg viewBox="0 0 100 100"><rect x="25" y="20" width="50" height="60" rx="10" fill="none" stroke="#1D1D1F" stroke-width="2.5"/><line x1="35" y1="35" x2="65" y2="35" stroke="#1D1D1F" stroke-width="2"/></svg></div>
      </a>
      <a class="small-card" style="background:var(--fog);" href="{% if p_bags != blank %}{{ p_bags.url }}{% else %}/collections/equipment{% endif %}">
        <h4>Board Bags</h4>
        <p>Padded, weatherproof, airline-ready.</p>
        <span style="color: var(--blue); font-size: 13px;">Shop &gt;</span>
        <div class="visual"><svg viewBox="0 0 100 100"><rect x="15" y="25" width="70" height="50" rx="8" fill="none" stroke="#1D1D1F" stroke-width="2.5"/><path d="M35 25 v-8 h30 v8" fill="none" stroke="#1D1D1F" stroke-width="2.5"/></svg></div>
      </a>
      <a class="small-card" style="background:var(--fog);" href="{% if p_kits != blank %}{{ p_kits.url }}{% else %}/collections/equipment{% endif %}">
        <h4>Tuning Kits</h4>
        <p>Wax, edge tools, and everything between.</p>
        <span style="color: var(--blue); font-size: 13px;">Shop &gt;</span>
        <div class="visual"><svg viewBox="0 0 100 100"><circle cx="50" cy="35" r="14" fill="none" stroke="#1D1D1F" stroke-width="2.5"/><line x1="50" y1="49" x2="50" y2="82" stroke="#1D1D1F" stroke-width="2.5"/></svg></div>
      </a>
      <a class="small-card" style="background:var(--fog);" href="{% if p_poles != blank %}{{ p_poles.url }}{% else %}/collections/equipment{% endif %}">
        <h4>Poles &amp; Straps</h4>
        <p>Lightweight carry for the walk to the lift.</p>
        <span style="color: var(--blue); font-size: 13px;">Shop &gt;</span>
        <div class="visual"><svg viewBox="0 0 100 100"><line x1="30" y1="15" x2="70" y2="85" stroke="#1D1D1F" stroke-width="3"/><circle cx="30" cy="15" r="6" fill="#1D1D1F"/></svg></div>
      </a>
    </div>
  </section>

  <section class="section fog">
    <div class="section-head reveal">
      <h2>Why ride Quantora.</h2>
    </div>
    <div class="feat-grid reveal">
      <div class="feat">
        <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z"/></svg></div>
        <h4>Tested at altitude</h4>
        <p>Every board is ridden on real terrain before it's approved to ship.</p>
      </div>
      <div class="feat">
        <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0z"/><path d="M9 12l2 2 4-4"/></svg></div>
        <h4>30-day returns</h4>
        <p>Unridden gear ships back free, full refund, no questions.</p>
      </div>
      <div class="feat">
        <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="15" height="10" rx="1"/><path d="M17 10h4l3 3v4h-7"/></svg></div>
        <h4>Free shipping</h4>
        <p>On every order over ₱5,000, nationwide.</p>
      </div>
      <div class="feat">
        <div class="icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21l7.8-7.8 1-1a5.5 5.5 0 000-7.6z"/></svg></div>
        <h4>2-season warranty</h4>
        <p>On bindings and hardware, no fine print.</p>
      </div>
    </div>
  </section>

  <section class="section" id="compare">
    <div class="section-head reveal">
      <h2>Find your model.</h2>
      <p class="sub">Three shapes, three lines down the mountain.</p>
    </div>
    <div class="compare reveal">
      <table>
        <thead>
          <tr>
            <th></th>
            <th>
              Alpenglow<br>Freeride 158
              {% if p_alpenglow != blank %}
                <br><a href="{{ p_alpenglow.url }}" class="compare-shop-link">Shop &gt;</a>
              {% endif %}
            </th>
            <th>
              Couloir<br>All-Mountain 154
              {% if p_couloir != blank %}
                <br><a href="{{ p_couloir.url }}" class="compare-shop-link">Shop &gt;</a>
              {% endif %}
            </th>
            <th>
              Drift<br>Park Twin 150
              {% if p_drift != blank %}
                <br><a href="{{ p_drift.url }}" class="compare-shop-link">Shop &gt;</a>
              {% endif %}
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Best for</td>
            <td>Deep snow, big lines</td>
            <td>Everyday, everywhere</td>
            <td>Park, jibs, jumps</td>
          </tr>
          <tr>
            <td>Flex</td>
            <td>7 / 10</td>
            <td>5 / 10</td>
            <td>4 / 10</td>
          </tr>
          <tr>
            <td>Shape</td>
            <td>Directional</td>
            <td>Directional twin</td>
            <td>True twin</td>
          </tr>
          <tr>
            <td>Rider level</td>
            <td>Advanced</td>
            <td>All levels</td>
            <td>Intermediate+</td>
          </tr>
          <tr>
            <td>Price</td>
            <td class="yes">{% if p_alpenglow != blank %}{{ p_alpenglow.price | money }}{% else %}₱24,900{% endif %}</td>
            <td class="yes">{% if p_couloir != blank %}{{ p_couloir.price | money }}{% else %}₱21,500{% endif %}</td>
            <td class="yes">{% if p_drift != blank %}{{ p_drift.price | money }}{% else %}₱19,900{% endif %}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>
</div>

<style>
  .quantora-apple-layout {
    --white: #ffffff;
    --fog: #F5F5F7;
    --fog-2: #E8E8ED;
    --ink: #1D1D1F;
    --ink-soft: #6E6E73;
    --blue: #0071E3;
    --blue-hover: #0077ED;
    --black: #000000;
    --black-2: #0B0B0C;
    
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Inter', 'Helvetica Neue', Arial, sans-serif;
    background: var(--white);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  
  .quantora-apple-layout a { text-decoration: none; color: inherit; }
  .quantora-apple-layout img, .quantora-apple-layout svg { display: block; max-width: 100%; }

  .quantora-apple-layout .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1);
  }
  
  .quantora-apple-layout .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .quantora-apple-layout .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .quantora-apple-layout .hero {
    padding: 120px 20px 80px;
    text-align: center;
    background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  }
  
  .quantora-apple-layout .eyebrow {
    font-size: 19px;
    font-weight: 600;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  
  .quantora-apple-layout .hero h1 {
    font-size: clamp(40px, 6.5vw, 80px);
    font-weight: 700;
    letter-spacing: -.015em;
    line-height: 1.05;
    margin-bottom: 14px;
    color: var(--ink) !important;
  }
  
  .quantora-apple-layout .hero .sub {
    font-size: clamp(19px, 2.2vw, 27px);
    color: var(--ink-soft);
    font-weight: 500;
    margin-bottom: 22px;
  }
  
  .quantora-apple-layout .cta-row {
    display: flex;
    gap: 28px;
    justify-content: center;
    align-items: center;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }
  
  .quantora-apple-layout .link-blue {
    color: var(--blue);
    font-size: 19px;
    font-weight: 400;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: none !important;
    background: none !important;
    padding: 0 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
  }
  
  .quantora-apple-layout .link-blue svg { transition: transform .2s ease; }
  .quantora-apple-layout .link-blue:hover svg { transform: translateX(3px); }
  .quantora-apple-layout .link-blue:hover { color: var(--blue-hover); background: none !important; }

  .quantora-apple-layout .pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 22px;
    border-radius: 980px !important;
    font-size: 17px;
    font-weight: 400;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease;
    text-transform: none !important;
    letter-spacing: normal !important;
    border: none !important;
  }
  
  .quantora-apple-layout .pill-dark { background: var(--ink); color: var(--white); }
  .quantora-apple-layout .pill-dark:hover { background: #3a3a3c; color: var(--white) !important; }
  .quantora-apple-layout .pill-blue { background: var(--blue); color: var(--white); }
  .quantora-apple-layout .pill-blue:hover { background: var(--blue-hover); color: var(--white) !important; }

  .quantora-apple-layout .hero-visual { max-width: 920px; margin: 0 auto; }
  
  .quantora-apple-layout .stage {
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .quantora-apple-layout .stage svg { width: auto; height: 70%; }

  .quantora-apple-layout .section { padding: 100px 20px; text-align: center; }
  .quantora-apple-layout .section.dark { background: var(--black); color: var(--white); }
  .quantora-apple-layout .section.fog { background: var(--fog); }
  
  .quantora-apple-layout .section-head h2 {
    font-size: clamp(32px, 4.6vw, 56px);
    font-weight: 700;
    letter-spacing: -.015em;
    line-height: 1.08;
    margin-bottom: 10px;
    color: inherit !important;
  }
  
  .quantora-apple-layout .section-head .sub {
    font-size: clamp(17px, 1.8vw, 21px);
    color: var(--ink-soft);
    font-weight: 500;
    max-width: 560px;
    margin: 0 auto 30px;
  }
  
  .quantora-apple-layout .section.dark .section-head .sub { color: #9a9a9e; }
  .quantora-apple-layout .links-inline { display: flex; gap: 24px; justify-content: center; margin-bottom: 50px; flex-wrap: wrap; }

  .quantora-apple-layout .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 1024px; margin: 0 auto; }
  .quantora-apple-layout .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 1024px; margin: 0 auto; }
  
  .quantora-apple-layout .prod-card {
    border-radius: 24px;
    padding: 44px 32px;
    text-align: left;
    display: flex;
    flex-direction: column;
    min-height: 420px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  .quantora-apple-layout .prod-card:hover { transform: scale(1.01); }
  .quantora-apple-layout .prod-card .eyebrow-sm { font-size: 13px; font-weight: 600; color: var(--ink-soft); margin-bottom: 6px; }
  .quantora-apple-layout .prod-card h3 { font-size: 28px; font-weight: 700; letter-spacing: -.01em; margin-bottom: 8px; color: inherit !important; }
  .quantora-apple-layout .prod-card p { font-size: 15px; color: var(--ink-soft); margin-bottom: 18px; max-width: 280px; }
  
  .quantora-apple-layout .prod-card .links { display: flex; gap: 18px; margin-bottom: auto; }
  .quantora-apple-layout .prod-card .links span { font-size: 14px; color: var(--blue); font-weight: 500; }
  
  .quantora-apple-layout .prod-card .visual { margin-top: 20px; align-self: center; width: 100%; display: flex; justify-content: center; }
  .quantora-apple-layout .prod-card .visual svg { height: 150px; }

  .quantora-apple-layout .small-card {
    border-radius: 20px;
    padding: 30px 24px;
    text-align: left;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease;
    border: none !important;
  }
  .quantora-apple-layout .small-card:hover { transform: translateY(-4px); }
  .quantora-apple-layout .small-card h4 { font-size: 20px; font-weight: 700; margin-bottom: 6px; letter-spacing: -.005em; color: var(--ink) !important; }
  .quantora-apple-layout .small-card p { font-size: 13.5px; color: var(--ink-soft); margin-bottom: 14px; }
  .quantora-apple-layout .small-card .visual { margin-top: auto; display: flex; justify-content: center; padding-top: 14px; }
  .quantora-apple-layout .small-card .visual svg { height: 90px; }

  .quantora-apple-layout .feat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; max-width: 1024px; margin: 0 auto; text-align: left; }
  .quantora-apple-layout .feat { padding: 0 24px; }
  .quantora-apple-layout .feat .icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--fog-2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
    color: var(--blue);
  }
  .quantora-apple-layout .feat h4 { font-size: 17px; font-weight: 700; margin-bottom: 8px; letter-spacing: -.005em; color: var(--ink) !important; }
  .quantora-apple-layout .feat p { font-size: 14px; color: var(--ink-soft); line-height: 1.55; }

  .quantora-apple-layout .compare { max-width: 900px; margin: 0 auto; text-align: left; }
  .quantora-apple-layout .compare table { width: 100%; border-collapse: collapse; }
  .quantora-apple-layout .compare th, .quantora-apple-layout .compare td { padding: 20px 16px; border-bottom: 1px solid rgba(0,0,0,.08); font-size: 14px; }
  .quantora-apple-layout .compare th { font-size: 13px; color: var(--ink-soft); font-weight: 600; text-align: center; }
  .quantora-apple-layout .compare th:first-child { text-align: left; }
  .quantora-apple-layout .compare td:first-child { color: var(--ink-soft); font-weight: 500; }
  .quantora-apple-layout .compare td { text-align: center; }
  .quantora-apple-layout .compare td:first-child { text-align: left; }
  .quantora-apple-layout .compare td.yes { color: var(--blue); font-weight: 600; }
  .quantora-apple-layout .compare-shop-link { display: inline-block; margin-top: 6px; font-size: 12px; color: var(--blue); font-weight: 600; }
  .quantora-apple-layout .compare-shop-link:hover { color: var(--blue-hover); text-decoration: underline; }

  @media (max-width: 820px) {
    .quantora-apple-layout .grid-2 { grid-template-columns: 1fr; }
    .quantora-apple-layout .grid-4 { grid-template-columns: 1fr 1fr; }
    .quantora-apple-layout .feat-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  
  @media (max-width: 480px) {
    .quantora-apple-layout .grid-4 { grid-template-columns: 1fr; }
    .quantora-apple-layout .feat-grid { grid-template-columns: 1fr; }
    .quantora-apple-layout .cta-row { gap: 16px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const els = document.querySelectorAll('.quantora-apple-layout .reveal');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: .15 });
    els.forEach(el => io.observe(el));
  });
</script>

